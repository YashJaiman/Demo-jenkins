pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Source code checked out by Pipeline from SCM'
            }
        }

        stage('Build') {
            steps {
                echo 'Checking Python syntax'
                sh 'python3 -m py_compile app.py'
            }
        }

        stage('Test') {
            steps {
                echo 'Running app.py'
                sh 'python3 app.py'
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed.'
        }
    }
}
